# ─────────────────────────────────────────────────────────────
# Skylens — environment. Copy to .env.local and fill in.
# De publieke site werkt ZONDER deze waarden (demo/seed-modus).
# Login, aanvragen-opslag en betalingen activeren zodra je ze invult.
# ─────────────────────────────────────────────────────────────

# Supabase (project in EU-regio: Frankfurt / eu-central-1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (lead-credits + Connect voor commissie). Gebruik test-keys om te beginnen.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (transactionele e-mail + lead-alerts)
RESEND_API_KEY=
RESEND_FROM="Skylens <noreply@skylens.nl>"

# Algemeen
NEXT_PUBLIC_SITE_URL=http://localhost:3000
